# ===========================================
# Docker 环境变量
# 复制为 .env 并填入真实值
# ===========================================

# --- 必填 ---
# Tushare Pro token: https://tushare.pro/register
TUSHARE_TOKEN=your-tushare-pro-token-here

# DeepSeek API key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# --- DeepSeek 配置 (可选) ---
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_MODEL_BACKTEST=deepseek-v4-flash

# --- pyserver 连接 (可选, 容器内已自动配置为 http://pyserver:8001) ---
# PYSERVER_URL=http://pyserver:8001
# PYSERVER_TIMEOUT_MS=180000

# --- 端口覆盖 (可选) ---
# PY_PORT=8001
# WEB_PORT=3000

# --- PyPI 镜像 (国内 NAS 部署时强烈建议设置) ---
# 清华镜像: https://pypi.tuna.tsinghua.edu.cn/simple
# 阿里镜像: https://mirrors.aliyun.com/pypi/simple
# 中科大:   https://pypi.mirrors.ustc.edu.cn/simple
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# --- NAS 持久化数据根目录 (NAS 部署时必填) ---
# Synology:  /volume1/docker/scs
# QNAP:      /share/Container/scs
# 绿联:      /volume1/docker/scs
# 本地默认:  ./nas-data (相对于 docker-compose.yml)
# NAS_DATA_PATH=/volume1/docker/scs

# --- NAS 资源限制 (可选, 根据设备调整) ---
# 双核 2GB NAS:
#   PYSERVER_MEM_LIMIT=512m
#   PYSERVER_CPUS=1.0
#   WEB_MEM_LIMIT=512m
#   WEB_CPUS=1.0
# 四核 8GB NAS (默认):
#   PYSERVER_MEM_LIMIT=1g
#   PYSERVER_CPUS=1.0
#   WEB_MEM_LIMIT=1g
#   WEB_CPUS=1.0
